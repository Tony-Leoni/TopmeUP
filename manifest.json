{
  "manifest_version": 3,
  "name": "TopMe Up!",
  "version": "1.0.0",
  "description": "Smart AI-powered assistant to boost your resumes to the top automatically.",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "activeTab",
    "scripting",
    "notifications",
    "cookies"
  ],
  "host_permissions": [
    "*://*.hh.ru/*",
    "https://muddy-morning-2e14.ajuajaya764.workers.dev/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.hh.ru/*"],
      "js": ["content_scripts/common.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
